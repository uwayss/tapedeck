{
  "name": "@uwayss/tapedeck",
  "version": "0.0.0",
  "description": "Story-style media player for Expo. Pooled expo-video players, worklet-driven progress, slot-based chrome.",
  "license": "MIT",
  "author": "Uwayss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uwayss/tapedeck.git"
  },
  "keywords": [
    "expo",
    "react-native",
    "stories",
    "story",
    "video",
    "expo-video",
    "reanimated",
    "player"
  ],
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./core": {
      "react-native": "./src/core/index.ts",
      "import": {
        "types": "./lib/typescript/module/core/index.d.ts",
        "default": "./lib/module/core/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/core/index.d.ts",
        "default": "./lib/commonjs/core/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/.*"
  ],
  "sideEffects": false,
  "scripts": {
    "format": "prettier --write . --log-level warn",
    "format:check": "prettier --check . --log-level warn",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:cycles": "madge --circular --extensions ts,tsx src",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build": "bob build",
    "clean": "rm -rf lib",
    "checks": "npm run format && npm run lint:fix && npm run typecheck && npm run lint:cycles && npm run test",
    "checks:ci": "npm run format:check && npm run lint && npm run typecheck && npm run lint:cycles && npm run test",
    "prepare": "bob build"
  },
  "peerDependencies": {
    "expo-image": ">=57.0.0",
    "expo-video": ">=57.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.79.0",
    "react-native-gesture-handler": ">=2.28.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-worklets": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "expo-image": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expo-image": "~57.0.0",
    "expo-video": "~57.0.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "madge": "^8.0.0",
    "prettier": "^3.9.5",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-worklets": "~0.10.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "example"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "dependencies": {},
  "overrides": {
    "typescript": "~5.9.3"
  }
}
